section .text
global main

test:
    push rbp
    mov rbp, rsp
    sub rsp, 64

    ; Block: test_entry
    mov rax, 1
    mov [rbp-8], rax  ; init a
    mov rax, 2
    mov [rbp-16], rax  ; init b
    mov rax, [rbp-8]
    mov [rbp-32], rax  ; load a
    mov rax, [rbp-16]
    mov [rbp-40], rax  ; load b
    mov rax, [rbp-32]
    mov rdx, [rbp-40]
    add rax, rdx  ; t0 + t1
    mov [rbp-48], rax
    mov rax, [rbp-48]
    mov [rbp-24], rax  ; init c
    jmp .test_exit

    .test_exit:
    add rsp, 64
    pop rbp
    ret