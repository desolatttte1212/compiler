section .text
global main

calc:
    push rbp
    mov rbp, rsp
    sub rsp, 80

    ; Block: calc_entry
    mov r8, [rbp-16]
    mov eax, [rbp-24]
    mov [r8], eax
    mov r8, [rbp-16]
    mov eax, [r8]
    mov [rbp-32], eax  ; load x
    mov rax, [rbp-32]
    mov rdx, 10
    add rax, rdx  ; t2 + 10
    mov [rbp-40], rax
    mov rax, [rbp-40]
    mov rdx, 2
    imul rax, rdx  ; t3 * 2
    mov [rbp-48], rax
    mov rax, 5
    cqo
    mov rcx, 1
    idiv rcx  ; 5 / 1
    mov [rbp-56], rax
    mov rax, [rbp-48]
    mov rdx, [rbp-56]
    sub rax, rdx  ; t4 - t5
    mov [rbp-64], rax
    mov eax, [rbp-64]  ; return value
    jmp .calc_exit

    .calc_exit:
    add rsp, 80
    pop rbp
    ret