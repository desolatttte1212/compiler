fn factorial(int n) = int {
    int result = 1;
    while (n > 0) {
        result = result * n;
        n = n - 1;
    }
    return result;
}

fn sum(int a, int b) = int {
    return a + b;
}

fn main() = void {
    int x = factorial(5);
    int y = sum(10, 20);
    int z = x + y;
}