fn main() = void {
    // Тест приоритета: * перед +
    int a = 1 + 2 * 3;

    // Тест приоритета: () меняет порядок
    int b = (1 + 2) * 3;

    // Тест приоритета: && перед ||
    bool c = true || false && false;

    // Тест приоритета: сравнение перед логическими
    bool d = 1 < 2 && 3 > 1;

    // Тест приоритета: унарные перед бинарными
    int e = -1 + 2;

    // Тест приоритета: присваивание правоассоциативное
    int x = 0;
    int y = 0;
    x = y = 5;
}