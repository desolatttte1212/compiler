fn main() = void {
    int x = 0;
    int y = 0;

    // Вложенные if
    if (x > 0) {
        if (y > 0) {
            x = x + 1;
        } else {
            x = x - 1;
        }
    } else {
        if (y < 0) {
            x = x + 2;
        }
    }

    // Вложенные while
    while (x < 10) {
        while (y < 5) {
            y = y + 1;
        }
        x = x + 1;
    }

    // if внутри while
    while (x > 0) {
        if (x % 2 == 0) {
            x = x - 2;
        } else {
            x = x - 1;
        }
    }
}