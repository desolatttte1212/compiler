section .text
global main

test:
    push rbp
    mov rbp, rsp
    sub rsp, 48

    ; Block: test_entry
    mov r8, [rbp-16]
    mov eax, [rbp-24]
    mov [r8], eax
    mov r8, [rbp-16]
    mov eax, [r8]
    mov [rbp-32], eax  ; load x
    mov rax, [rbp-32]
    mov rdx, 0
    cmp rax, rdx  ; t2 > 0
    setg al
    movzx eax, al
    mov [rbp-40], eax
    mov rax, [rbp-40]
    test rax, rax
    jz .L_then0  ; if condition

    ; Block: L_else1
.L_else1:
    jmp .L_join2

    ; Block: L_then0
.L_then0:
    mov eax, 1  ; return value
    jmp .test_exit

    ; Block: L_join2
.L_join2:
    mov eax, 0  ; return value
    jmp .test_exit

    .test_exit:
    add rsp, 48
    pop rbp
    ret
