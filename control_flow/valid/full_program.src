// Полная интеграционная программа (Спринт 6)
// Проверяет: вложенные условия, циклы, логику и арифметику в одном файле.

fn exit(int code) = void { }

fn main() = void {
    int i = 0;
    int sum = 0;
    int limit = 5;

    // Тест 1: Цикл while + условие внутри
    while (i < limit) {
        // Если i четное, добавляем к сумме
        if (i % 2 == 0) {
            sum = sum + i;
        }
        i = i + 1;
    }

    // Ожидаемая сумма четных чисел от 0 до 4: 0 + 2 + 4 = 6
    // Если sum != 6, завершаем с ошибкой (код 1)
    if (sum != 6) {
        exit(1);
    }

    // Тест 2: Короткое замыкание &&
    int a = 0;
    int b = 10;
    // a != 0 ложно, значит (b / a) не должно вычисляться (иначе краш)
    if (a != 0 && b / a > 5) {
        exit(1); // Сюда не должны попасть
    }

    // Тест 3: Короткое замыкание ||
    // a == 0 истинно, значит правая часть не вычисляется
    if (a == 0 || b / a == 2) {
        // Все верно, выходим с успехом
        exit(0);
    } else {
        exit(1);
    }
}